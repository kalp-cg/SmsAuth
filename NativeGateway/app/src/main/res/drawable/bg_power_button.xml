<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/pulse_power_on"
                android:startColor="@color/pulse_mint" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/pulse_power_off"
                android:startColor="@color/pulse_navy" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
